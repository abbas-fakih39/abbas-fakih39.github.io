---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="fixed top-0 left-0 right-0 z-50 bg-bg border-b border-fg-dim">
  <div class="max-w-content w-full mx-auto flex items-center justify-between h-14 px-6 lg:px-16">

    <a
      href={`/${lang}`}
      class="font-display font-black text-sm text-fg hover:text-accent transition-colors duration-300"
    >
      AZF
    </a>

    <nav class="hidden md:flex items-center gap-10" aria-label="Navigation">
      <a href={`/${lang}#about`}    class="font-mono text-[10px] tracking-[0.18em] uppercase text-fg-muted hover:text-fg transition-colors duration-300">{t('nav.about')}</a>
      <a href={`/${lang}#skills`}   class="font-mono text-[10px] tracking-[0.18em] uppercase text-fg-muted hover:text-fg transition-colors duration-300">{t('nav.skills')}</a>
      <a href={`/${lang}#projects`} class="font-mono text-[10px] tracking-[0.18em] uppercase text-fg-muted hover:text-fg transition-colors duration-300">{t('nav.projects')}</a>
      <a href={`/${lang}#contact`}  class="font-mono text-[10px] tracking-[0.18em] uppercase text-fg-muted hover:text-fg transition-colors duration-300">{t('nav.contact')}</a>
    </nav>

    <LanguageSwitcher />
  </div>
</header>

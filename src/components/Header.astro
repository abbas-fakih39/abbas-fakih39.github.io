---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="fixed top-0 left-0 right-0 z-50 h-14 bg-bg/95 backdrop-blur-sm border-b border-border">
  <div class="max-w-content w-full mx-auto flex items-center justify-between h-full px-6 lg:px-12">

    <a
      href={`/${lang}`}
      class="font-mono text-sm font-medium text-fg hover:text-accent transition-colors duration-200"
    >
      AF
    </a>

    <nav class="hidden md:flex items-center gap-8" aria-label="Navigation">
      <a href={`/${lang}#about`}    class="text-[13px] font-medium text-fg-mid hover:text-fg transition-colors duration-200">{t('nav.about')}</a>
      <a href={`/${lang}#skills`}   class="text-[13px] font-medium text-fg-mid hover:text-fg transition-colors duration-200">{t('nav.skills')}</a>
      <a href={`/${lang}#projects`} class="text-[13px] font-medium text-fg-mid hover:text-fg transition-colors duration-200">{t('nav.projects')}</a>
      <a href={`/${lang}#contact`}  class="text-[13px] font-medium text-fg-mid hover:text-fg transition-colors duration-200">{t('nav.contact')}</a>
    </nav>

    <LanguageSwitcher />
  </div>
</header>

---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const protocols = [
  { label: 'Email',    value: 'abbassfakih54321@outlook.com', href: 'mailto:abbassfakih54321@outlook.com', external: false },
  { label: 'Phone',    value: '+33 07 69 51 81 92',           href: 'tel:+33769518192',                    external: false },
  { label: 'GitHub',   value: 'github.com/abbas-fakih39',     href: 'https://github.com/abbas-fakih39',    external: true },
  { label: 'LinkedIn', value: 'linkedin.com/in/abbas-zein-fakih', href: 'https://www.linkedin.com/in/abbas-zein-fakih-b8649022b/', external: true },
];
---

<section id="contact" class="pt-24 sm:pt-32">
  <div class="max-w-content w-full mx-auto px-6 lg:px-12">

    <!-- Section title over drawn rule -->
    <h2 class="section-title type-display uppercase text-fluid-title text-ink pb-4">
      {t('contact.title')}
    </h2>
    <div class="section-rule w-full" aria-hidden="true"></div>

    <!-- CTA headline -->
    <p class="contact-cta mt-14 sm:mt-20 type-display uppercase text-fluid-display text-ink">
      {t('contact.cta1')}<br />
      <span class="text-signal">{t('contact.cta2')}</span>
    </p>

    <!-- Split: info | form -->
    <div class="mt-14 sm:mt-20 grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-14 lg:gap-20 pb-24 sm:pb-32">

      <!-- Left: subtext + links -->
      <div class="contact-info">
        <p class="text-muted leading-relaxed max-w-sm mb-12">
          {t('contact.subtext')}
        </p>

        <h3 class="text-base font-bold text-ink mb-6">
          {t('contact.protocols')}
        </h3>

        <ul class="space-y-1">
          {protocols.map((p) => (
            <li>
              <a
                href={p.href}
                target={p.external ? '_blank' : undefined}
                rel={p.external ? 'noopener noreferrer' : undefined}
                class="group flex items-baseline gap-4 py-2 min-h-[44px]"
              >
                <span class="text-[13px] font-semibold text-ink w-20 flex-shrink-0">{p.label}</span>
                <span class="text-[15px] text-muted group-hover:text-signal transition-colors duration-200 break-all">{p.value}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: form on raised panel -->
      <div class="contact-form-panel bg-surface border border-line rounded-[4px] p-7 sm:p-10">
        <form id="contact-form" class="space-y-7">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-7">
            <div class="form-field">
              <label for="name">{t('contact.form.name')}</label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="form-field">
              <label for="email">{t('contact.form.email')}</label>
              <input type="email" id="email" name="email" required />
            </div>
          </div>
          <div class="form-field">
            <label for="subject">{t('contact.form.subject')}</label>
            <input type="text" id="subject" name="subject" required />
          </div>
          <div class="form-field">
            <label for="message">{t('contact.form.message')}</label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>
          <button
            type="submit"
            id="submit-btn"
            class="px-7 py-3.5 bg-signal text-signal-ink text-sm font-semibold hover:brightness-110 transition-[filter] duration-200 disabled:opacity-60"
          >
            {t('contact.form.send')}
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

<script is:inline src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js" />
<script is:inline>
  (function() {
    emailjs.init("bLECYSz1NM7GcjAev");
    const form = document.getElementById('contact-form');
    const btn  = document.getElementById('submit-btn');

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const originalText = btn.textContent;
      btn.textContent = '...';
      btn.disabled = true;

      emailjs.sendForm('service_jq5ib7h', 'template_m3asgjl', form)
        .then(() => {
          btn.textContent = '✓ Sent';
          btn.style.background = 'var(--ok)';
          form.reset();
          setTimeout(() => {
            btn.textContent = originalText;
            btn.style.background = '';
            btn.disabled = false;
          }, 4000);
        })
        .catch(() => {
          btn.textContent = '✕ Error';
          btn.style.background = 'var(--danger)';
          setTimeout(() => {
            btn.textContent = originalText;
            btn.style.background = '';
            btn.disabled = false;
          }, 4000);
        });
    });
  })();
</script>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    gsap.from('#contact .section-rule', {
      scaleX: 0, duration: 1, ease: 'power4.out',
      scrollTrigger: { trigger: '#contact', start: 'top 78%' },
    });
    gsap.from('#contact .section-title', {
      y: 24, opacity: 0, duration: 0.7, ease: 'power4.out',
      scrollTrigger: { trigger: '#contact', start: 'top 78%' },
    });
    gsap.from('#contact .contact-cta', {
      y: 30, opacity: 0, duration: 0.8, ease: 'power4.out',
      scrollTrigger: { trigger: '#contact .contact-cta', start: 'top 85%' },
    });
    gsap.from(['#contact .contact-info', '#contact .contact-form-panel'], {
      y: 36, opacity: 0, duration: 0.8, stagger: 0.15, ease: 'power4.out',
      scrollTrigger: { trigger: '#contact .contact-info', start: 'top 85%' },
    });
  }
</script>

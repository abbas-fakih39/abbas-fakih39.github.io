---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="home" class="min-h-[100svh] flex flex-col justify-center pt-16">
  <div class="max-w-content w-full mx-auto px-6 lg:px-12">

    <!-- Availability: plain sentence with signal marker -->
    <p class="hero-line flex items-center gap-3 text-sm font-medium text-muted mb-8">
      <span class="w-2 h-2 rounded-[2px] bg-signal inline-block flex-shrink-0" aria-hidden="true"></span>
      {t('hero.availability')}
    </p>

    <!-- Poster name -->
    <h1 class="type-display uppercase text-fluid-hero text-ink">
      <span class="hero-mask block overflow-hidden"><span class="hero-line-inner block">Abbas</span></span>
      <span class="hero-mask block overflow-hidden"><span class="hero-line-inner block">Zein Fakih</span></span>
    </h1>

    <!-- Subtitle -->
    <p class="hero-line mt-8 text-fluid-xl text-ink font-medium max-w-xl">
      {t('hero.subtitle')} <span class="text-muted">— Lille, France</span>
    </p>

    <!-- CTAs -->
    <div class="hero-line mt-12 flex flex-wrap items-center gap-6">
      <a
        href="/cv/mon-cv.pdf"
        download
        class="inline-flex items-center gap-2 px-7 py-3.5 bg-signal text-signal-ink text-sm font-semibold hover:brightness-110 transition-[filter] duration-200"
      >
        {t('hero.download_cv')}
        <span aria-hidden="true">↓</span>
      </a>
      <a
        href={`/${lang}#projects`}
        class="inline-flex items-center gap-2 py-3 text-sm font-semibold text-ink underline underline-offset-8 decoration-line hover:decoration-signal hover:text-signal transition-colors duration-200"
      >
        {t('hero.my_projects')}
        <span aria-hidden="true">→</span>
      </a>
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    const tl = gsap.timeline({ defaults: { ease: 'power4.out' } });

    tl.from('.hero-line-inner', {
      yPercent: 110,
      duration: 1,
      stagger: 0.12,
    })
      .from('.hero-line', {
        opacity: 0,
        y: 20,
        duration: 0.7,
        stagger: 0.1,
      }, '-=0.6');
  }
</script>

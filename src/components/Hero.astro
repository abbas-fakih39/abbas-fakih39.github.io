---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="home" class="min-h-[100svh] flex flex-col items-center justify-center text-center px-6 pt-14">

  <!-- Status chip -->
  <div class="hero-chip inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-accent/30 bg-accent-bg mb-10">
    <span class="w-1.5 h-1.5 rounded-full bg-accent inline-block"></span>
    <span class="font-mono text-[11px] text-accent tracking-wide">{t('hero.availability')}</span>
  </div>

  <!-- Name -->
  <h1 class="hero-name font-display font-bold text-fluid-hero text-fg leading-[0.9] tracking-tight mb-6">
    Abbas Fakih
  </h1>

  <!-- Subtitle -->
  <p class="hero-sub text-fluid-xl text-fg-mid font-normal mb-8 max-w-md">
    {t('hero.subtitle')} &mdash; Lille, France
  </p>

  <!-- Divider -->
  <div class="hero-divider w-12 h-px bg-border mb-10"></div>

  <!-- CTAs -->
  <div class="hero-cta flex flex-wrap items-center justify-center gap-4">
    <a
      href="/cv/mon-cv.pdf"
      download
      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent text-white text-[13px] font-medium hover:bg-blue-700 transition-colors duration-200"
    >
      {t('hero.download_cv')}
      <span class="text-xs">↓</span>
    </a>
    <a
      href={`/${lang}#projects`}
      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-border text-[13px] font-medium text-fg-mid hover:border-fg hover:text-fg transition-all duration-200"
    >
      {t('hero.my_projects')}
      <span class="text-xs">→</span>
    </a>
  </div>

</section>

<script>
  import gsap from 'gsap';

  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

  tl.to('.hero-chip',    { opacity: 1, y: 0, duration: 0.6 })
    .to('.hero-name',    { opacity: 1, y: 0, duration: 0.7 }, '-=0.3')
    .to('.hero-sub',     { opacity: 1, y: 0, duration: 0.6 }, '-=0.4')
    .to('.hero-divider', { opacity: 1, y: 0, duration: 0.4 }, '-=0.35')
    .to('.hero-cta',     { opacity: 1, y: 0, duration: 0.5 }, '-=0.3');
</script>

---
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const otherLang = lang === 'fr' ? 'en' : 'fr';
---

<a
  href={`/${otherLang}`}
  class="font-mono text-[10px] tracking-[0.18em] uppercase text-fg-muted hover:text-fg transition-colors duration-300"
>
  <span class="text-fg">{lang.toUpperCase()}</span>
  <span class="text-fg-dim mx-0.5">/</span>
  <span>{otherLang.toUpperCase()}</span>
</a>

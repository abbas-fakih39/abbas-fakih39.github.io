---
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const otherLang = lang === 'fr' ? 'en' : 'fr';
---

<a
  href={`/${otherLang}`}
  class="inline-flex items-center min-h-[44px] text-[13px] font-medium text-muted hover:text-signal transition-colors duration-200"
  aria-label={otherLang === 'fr' ? 'Passer en français' : 'Switch to English'}
>
  <span class="text-ink font-semibold">{lang.toUpperCase()}</span>
  <span class="mx-1 text-line">/</span>
  <span>{otherLang.toUpperCase()}</span>
</a>

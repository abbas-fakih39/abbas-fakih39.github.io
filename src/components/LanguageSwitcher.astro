---
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const otherLang = lang === 'fr' ? 'en' : 'fr';
---

<a
  href={`/${otherLang}`}
  class="font-mono text-[12px] text-fg-mid hover:text-fg transition-colors duration-200"
>
  <span class="text-fg font-medium">{lang.toUpperCase()}</span>
  <span class="text-fg-dim mx-0.5">/</span>
  <span>{otherLang.toUpperCase()}</span>
</a>

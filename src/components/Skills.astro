---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const groups = [
  {
    label: t('skills.group1'),
    items: ['React', 'Node.js', 'TypeScript', 'MongoDB', 'Express', 'REST API'],
  },
  {
    label: t('skills.group2'),
    items: ['Next.js', 'NestJS', 'Laravel', 'PHP', 'PostgreSQL', 'Prisma', 'Docker', 'SvelteKit'],
  },
  {
    label: t('skills.group3'),
    items: ['Git / GitHub', 'Postman', 'Figma', 'Linux', 'Agile / Scrum'],
  },
];

const canDo = [
  t('skills.cando1'),
  t('skills.cando2'),
  t('skills.cando3'),
  t('skills.cando4'),
];
---

<section id="skills" class="border-t border-border">
  <div class="max-w-content w-full mx-auto px-6 lg:px-12">

    <!-- Section header -->
    <div class="flex items-center gap-4 py-5 border-b border-border section-header-anim">
      <span class="font-mono text-[11px] text-fg-dim tracking-widest">02</span>
      <span class="w-px h-4 bg-border"></span>
      <span class="font-mono text-[11px] uppercase tracking-widest text-fg-dim">{t('skills.label')}</span>
    </div>

    <!-- Three skill groups -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 py-12 sm:py-16 border-b border-border fade-up">
      {groups.map((group) => (
        <div>
          <p class="font-mono text-[10px] tracking-widest uppercase text-fg-dim mb-5">
            {group.label}
          </p>
          <div class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span class="px-3 py-1.5 rounded-full bg-surface text-fg-mid text-[13px] font-medium border border-border hover:bg-accent-bg hover:text-accent hover:border-accent/30 transition-all duration-200 cursor-default">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Can-do -->
    <div class="py-10 sm:py-12 fade-up">
      <p class="font-mono text-[10px] tracking-widest uppercase text-fg-dim mb-6">
        {t('skills.cando')}
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {canDo.map((item) => (
          <div class="flex items-start gap-3">
            <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0"></span>
            <p class="text-fg-mid text-[14px] sm:text-[15px] leading-relaxed">{item}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.to('#skills .section-header-anim', {
    opacity: 1, y: 0, duration: 0.6,
    scrollTrigger: { trigger: '#skills', start: 'top 78%' },
  });

  gsap.utils.toArray<HTMLElement>('#skills .fade-up').forEach((el, i) => {
    gsap.to(el, {
      opacity: 1, y: 0, duration: 0.7,
      delay: i * 0.08,
      scrollTrigger: { trigger: el, start: 'top 82%' },
    });
  });
</script>

---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const groups = [
  {
    label: t('skills.group1'),
    items: ['Next.js', 'Prisma', 'PostgreSQL', 'React', 'Node.js', 'TypeScript', 'Express'],
  },
  {
    label: t('skills.group2'),
    items: ['REST API', 'MongoDB', 'NestJS', 'Laravel', 'PHP', 'Docker', 'SvelteKit'],
  },
  {
    label: t('skills.group3'),
    items: ['Git / GitHub', 'Postman', 'Figma', 'Linux'],
  },
];

const canDo = [
  t('skills.cando1'),
  t('skills.cando2'),
  t('skills.cando3'),
  t('skills.cando4'),
];
---

<section id="skills" class="pt-24 sm:pt-32">
  <div class="max-w-content w-full mx-auto px-6 lg:px-12">

    <!-- Section title over drawn rule -->
    <h2 class="section-title type-display uppercase text-fluid-title text-ink pb-4">
      {t('skills.title')}
    </h2>
    <div class="section-rule w-full" aria-hidden="true"></div>

    <!-- Skill groups as full-width rows -->
    <div class="mt-6">
      {groups.map((group) => (
        <div class="skill-row grid grid-cols-1 md:grid-cols-[240px_1fr] gap-3 md:gap-10 py-8 sm:py-10 border-b border-line">
          <h3 class="type-display uppercase text-lg text-ink" style="font-stretch: 115%;">
            {group.label}
          </h3>
          <p class="text-fluid-xl font-medium text-muted leading-relaxed">
            {group.items.map((item, i) => (
              <>
                <span class="hover:text-signal transition-colors duration-200 cursor-default">{item}</span>{i < group.items.length - 1 && ', '}
              </>
            ))}
          </p>
        </div>
      ))}
    </div>

    <!-- Can-do -->
    <div class="cando mt-12 sm:mt-16">
      <h3 class="text-base font-bold text-ink mb-6">
        {t('skills.cando')}
      </h3>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-5 max-w-4xl">
        {canDo.map((item) => (
          <li class="flex items-start gap-3">
            <span class="mt-[0.55em] w-2 h-2 rounded-[2px] bg-signal flex-shrink-0" aria-hidden="true"></span>
            <p class="text-muted leading-relaxed">{item}</p>
          </li>
        ))}
      </ul>
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    gsap.from('#skills .section-rule', {
      scaleX: 0, duration: 1, ease: 'power4.out',
      scrollTrigger: { trigger: '#skills', start: 'top 78%' },
    });
    gsap.from('#skills .section-title', {
      y: 24, opacity: 0, duration: 0.7, ease: 'power4.out',
      scrollTrigger: { trigger: '#skills', start: 'top 78%' },
    });
    gsap.utils.toArray<HTMLElement>('#skills .skill-row').forEach((row) => {
      gsap.from(row, {
        x: -40, opacity: 0, duration: 0.8, ease: 'power4.out',
        scrollTrigger: { trigger: row, start: 'top 85%' },
      });
    });
    gsap.from('#skills .cando', {
      y: 32, opacity: 0, duration: 0.7, ease: 'power4.out',
      scrollTrigger: { trigger: '#skills .cando', start: 'top 85%' },
    });
  }
</script>

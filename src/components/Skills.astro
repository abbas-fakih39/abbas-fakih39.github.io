---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const groups = [
  {
    label: t('skills.group1'),
    items: ['React', 'Node.js', 'TypeScript', 'MongoDB', 'Express', 'REST API'],
  },
  {
    label: t('skills.group2'),
    items: ['Next.js', 'NestJS', 'Laravel', 'PHP', 'PostgreSQL', 'Prisma', 'Docker', 'SvelteKit'],
  },
  {
    label: t('skills.group3'),
    items: ['Git / GitHub', 'Postman', 'Figma', 'Linux', 'Agile / Scrum'],
  },
];

const canDo = [
  t('skills.cando1'),
  t('skills.cando2'),
  t('skills.cando3'),
  t('skills.cando4'),
];
---

<section id="skills" class="border-t border-fg-dim">
  <div class="max-w-content w-full mx-auto px-6 lg:px-16">

    <!-- Section header -->
    <div class="flex items-baseline gap-5 py-5 border-b border-fg-dim section-header-anim">
      <span class="font-display font-black text-fg-dim text-3xl sm:text-4xl leading-none">02</span>
      <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-fg-muted">{t('skills.label')}</span>
    </div>

    <!-- Three-column grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 border-b border-fg-dim fade-up">
      {groups.map((group, i) => (
        <div class={`py-10 sm:py-14 ${i < 2 ? 'md:border-r md:border-fg-dim md:pr-10' : ''} ${i > 0 ? 'md:pl-10' : ''} ${i > 0 ? 'border-t md:border-t-0 border-fg-dim' : ''}`}>
          <p class="font-mono text-[9px] tracking-[0.2em] uppercase text-fg-dim mb-6">
            {group.label}
          </p>
          <ul class="space-y-3">
            {group.items.map((item) => (
              <li class="font-display font-semibold text-fg text-lg sm:text-xl leading-none">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Can-do items -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-0 fade-up">
      {canDo.map((item, i) => (
        <div class={`py-5 sm:py-6 text-fg-muted text-sm leading-relaxed ${i % 2 === 0 ? 'sm:border-r sm:border-fg-dim sm:pr-10' : 'sm:pl-10'} ${i < 2 ? 'border-b border-fg-dim' : ''}`}>
          <span class="text-fg-dim font-mono text-[9px] tracking-widest mr-3">—</span>
          {item}
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.to('#skills .section-header-anim', {
    opacity: 1, y: 0, duration: 0.7,
    scrollTrigger: { trigger: '#skills', start: 'top 75%' },
  });

  gsap.utils.toArray<HTMLElement>('#skills .fade-up').forEach((el, i) => {
    gsap.to(el, {
      opacity: 1, y: 0, duration: 0.8,
      delay: i * 0.1,
      scrollTrigger: { trigger: el, start: 'top 80%' },
    });
  });
</script>

---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projects = [
  {
    title: 'Kits & Kids',
    desc: lang === 'fr'
      ? "App mobile de location d'équipements bébé — calendrier et réservation."
      : 'Baby equipment rental mobile app — calendar and booking system.',
    tech: ['NestJS', 'NuxtJS', 'PostgreSQL'],
    link: 'https://github.com/abbas-fakih39/kids-project.git',
  },
  {
    title: 'E-Commerce Platform',
    desc: lang === 'fr'
      ? 'Plateforme e-commerce avec panier, auth et gestion des commandes.'
      : 'E-commerce platform with cart, auth and order management.',
    tech: ['React', 'Node.js', 'MongoDB'],
    link: 'https://github.com/twoofusllc-developement-team/productdeliveryplatform-server/tree/abbas-internship',
  },
  {
    title: 'Spotify Redesign',
    desc: lang === 'fr'
      ? "Refonte complète de l'interface Spotify avec nouvelles fonctionnalités."
      : "Full redesign of Spotify's interface with new features and improved UX.",
    tech: ['Laravel', 'PHP'],
    link: 'https://github.com/abbas-fakih39/spotify-redesign',
  },
  {
    title: 'Felikso',
    desc: lang === 'fr'
      ? "Site WordPress pour l'association lilloise Felikso."
      : 'WordPress website for the Lille association Felikso.',
    tech: ['WordPress'],
    link: 'https://www.felikso.org/',
  },
  {
    title: 'Tower Defense',
    desc: lang === 'fr'
      ? 'Jeu de stratégie Tower Defense — gestion de vagues et améliorations.'
      : 'Tower Defense strategy game with waves and upgrades system.',
    tech: ['Unity', 'C#'],
    link: 'https://github.com/ArthurFtn/Tower-defense',
  },
];
---

<section id="projects" class="border-t border-border">
  <div class="max-w-content w-full mx-auto px-6 lg:px-12">

    <!-- Section header -->
    <div class="flex items-center gap-4 py-5 border-b border-border section-header-anim">
      <span class="font-mono text-[11px] text-fg-dim tracking-widest">03</span>
      <span class="w-px h-4 bg-border"></span>
      <span class="font-mono text-[11px] uppercase tracking-widest text-fg-dim">{t('projects.label')}</span>
    </div>

  </div>

  <!-- Project rows -->
  {projects.map((project, i) => (
    <a
      href={project.link}
      target="_blank"
      rel="noopener noreferrer"
      class="group block border-t border-border hover:bg-surface transition-colors duration-200 fade-up"
    >
      <div class="max-w-content mx-auto px-6 lg:px-12 py-6 sm:py-7 flex items-center justify-between gap-6">

        <!-- Left: number + title + desc -->
        <div class="flex items-start sm:items-center gap-5 sm:gap-8 min-w-0 flex-1">
          <span class="font-mono text-[11px] text-fg-dim flex-shrink-0 tabular-nums mt-0.5 sm:mt-0">
            0{i + 1}
          </span>
          <div class="min-w-0">
            <h3 class="font-display font-semibold text-lg sm:text-xl text-fg group-hover:text-accent transition-colors duration-200 leading-tight">
              {project.title}
            </h3>
            <p class="hidden sm:block mt-1 text-[13px] text-fg-dim leading-relaxed truncate max-w-lg">
              {project.desc}
            </p>
          </div>
        </div>

        <!-- Right: tech pills + arrow -->
        <div class="flex items-center gap-3 flex-shrink-0">
          <div class="hidden lg:flex items-center gap-2">
            {project.tech.map((tech) => (
              <span class="px-2.5 py-1 rounded-full bg-surface border border-border text-[11px] font-mono text-fg-dim">
                {tech}
              </span>
            ))}
          </div>
          <span class="text-fg-dim group-hover:text-accent group-hover:translate-x-1 transition-all duration-200 text-base ml-2">→</span>
        </div>

      </div>
    </a>
  ))}

  <!-- GitHub CTA -->
  <div class="border-t border-border">
    <div class="max-w-content mx-auto px-6 lg:px-12 py-8 fade-up">
      <a
        href="https://github.com/abbas-fakih39"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-[13px] font-medium text-fg-mid hover:text-accent transition-colors duration-200"
      >
        {t('projects.github')}
        <span class="text-xs">→</span>
      </a>
    </div>
  </div>

</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.to('#projects .section-header-anim', {
    opacity: 1, y: 0, duration: 0.6,
    scrollTrigger: { trigger: '#projects', start: 'top 78%' },
  });

  gsap.utils.toArray<HTMLElement>('#projects .fade-up').forEach((el, i) => {
    gsap.to(el, {
      opacity: 1, y: 0, duration: 0.6,
      delay: i * 0.05,
      scrollTrigger: { trigger: el, start: 'top 87%' },
    });
  });
</script>

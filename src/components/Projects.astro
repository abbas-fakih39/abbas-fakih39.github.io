---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projects = [
  {
    title: 'Kits & Kids',
    desc: lang === 'fr'
      ? "App mobile de location d'équipements bébé — calendrier et réservation."
      : 'Baby equipment rental mobile app — calendar and booking system.',
    tech: ['NestJS', 'NuxtJS', 'PostgreSQL'],
    link: 'https://github.com/abbas-fakih39/kids-project.git',
  },
  {
    title: 'E-Commerce Platform',
    desc: lang === 'fr'
      ? 'Plateforme e-commerce avec panier, auth et gestion des commandes.'
      : 'E-commerce platform with cart, auth and order management.',
    tech: ['React', 'Node.js', 'MongoDB'],
    link: 'https://github.com/twoofusllc-developement-team/productdeliveryplatform-server/tree/abbas-internship',
  },
  {
    title: 'Spotify Redesign',
    desc: lang === 'fr'
      ? "Refonte complète de l'interface Spotify avec nouvelles fonctionnalités."
      : "Full redesign of Spotify's interface with new features and improved UX.",
    tech: ['Laravel', 'PHP'],
    link: 'https://github.com/abbas-fakih39/spotify-redesign',
  },
  {
    title: 'Felikso',
    desc: lang === 'fr'
      ? 'Site WordPress pour l\'association lilloise Felikso.'
      : 'WordPress website for the Lille association Felikso.',
    tech: ['WordPress'],
    link: 'https://www.felikso.org/',
  },
  {
    title: 'Tower Defense',
    desc: lang === 'fr'
      ? 'Jeu de stratégie Tower Defense — gestion de vagues et améliorations.'
      : 'Tower Defense strategy game with waves and upgrades system.',
    tech: ['Unity', 'C#'],
    link: 'https://github.com/ArthurFtn/Tower-defense',
  },
];
---

<section id="projects" class="border-t border-fg-dim">
  <div class="max-w-content w-full mx-auto px-6 lg:px-16">

    <!-- Section header -->
    <div class="flex items-baseline gap-5 py-5 border-b border-fg-dim section-header-anim">
      <span class="font-display font-black text-fg-dim text-3xl sm:text-4xl leading-none">03</span>
      <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-fg-muted">{t('projects.label')}</span>
    </div>

  </div>

  <!-- Project rows (full-width rules, content capped at max-content) -->
  {projects.map((project, i) => (
    <a
      href={project.link}
      target="_blank"
      rel="noopener noreferrer"
      class="project-row block border-t border-fg-dim transition-colors duration-300 hover:bg-[var(--accent-dim)] group fade-up"
    >
      <div class="max-w-content mx-auto px-6 lg:px-16 py-7 sm:py-9 flex items-center justify-between gap-6">

        <!-- Left: number + title -->
        <div class="flex items-baseline gap-5 sm:gap-8 min-w-0 flex-1">
          <span class="font-mono text-[10px] tracking-[0.2em] text-fg-dim flex-shrink-0 tabular-nums">
            0{i + 1}
          </span>
          <h3 class="font-display font-black text-fluid-xl text-fg leading-tight group-hover:text-accent transition-colors duration-300">
            {project.title}
          </h3>
        </div>

        <!-- Right: tech + arrow (desktop) -->
        <div class="hidden lg:flex items-center gap-4 flex-shrink-0">
          {project.tech.map((tech) => (
            <span class="font-mono text-[9px] tracking-[0.1em] uppercase text-fg-muted">{tech}</span>
          ))}
          <span class="ml-4 text-fg-muted group-hover:text-accent group-hover:translate-x-1 transition-all duration-300 text-base">→</span>
        </div>

        <!-- Arrow only (mobile) -->
        <span class="lg:hidden text-fg-muted group-hover:text-accent transition-colors duration-300 text-base flex-shrink-0">→</span>

      </div>
    </a>
  ))}

  <!-- Closing rule + GitHub CTA -->
  <div class="border-t border-fg-dim">
    <div class="max-w-content mx-auto px-6 lg:px-16 py-10 sm:py-12 fade-up">
      <a
        href="https://github.com/abbas-fakih39"
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-[10px] tracking-[0.18em] uppercase text-fg-muted hover:text-fg transition-colors duration-300 group"
      >
        {t('projects.github')}
        <span class="ml-2 inline-block group-hover:translate-x-0.5 transition-transform duration-200">→</span>
      </a>
    </div>
  </div>

</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.to('#projects .section-header-anim', {
    opacity: 1, y: 0, duration: 0.7,
    scrollTrigger: { trigger: '#projects', start: 'top 75%' },
  });

  gsap.utils.toArray<HTMLElement>('#projects .fade-up').forEach((el, i) => {
    gsap.to(el, {
      opacity: 1, y: 0, duration: 0.6,
      delay: i * 0.06,
      scrollTrigger: { trigger: el, start: 'top 85%' },
    });
  });
</script>

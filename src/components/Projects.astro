---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projects = [
  {
    title: 'Nexus',
    desc: lang === 'fr'
      ? "Application de gestion pour petits commerces — stock, ventes, achats, factures PDF et RH."
      : 'Management app for small businesses — inventory, sales, purchases, PDF invoicing and HR.',
    tech: ['React', 'NestJS', 'PostgreSQL'],
    link: 'https://github.com/abbas-fakih39/nexus',
  },
  {
    title: 'Kits & Kids',
    desc: lang === 'fr'
      ? "App mobile de location d'équipements bébé — calendrier et réservation."
      : 'Baby equipment rental mobile app — calendar and booking system.',
    tech: ['NestJS', 'NuxtJS', 'PostgreSQL'],
    link: 'https://github.com/abbas-fakih39/kids-project.git',
  },
  {
    title: 'E-Commerce Platform',
    desc: lang === 'fr'
      ? 'Plateforme e-commerce avec panier, auth et gestion des commandes.'
      : 'E-commerce platform with cart, auth and order management.',
    tech: ['React', 'Node.js', 'MongoDB'],
    link: 'https://github.com/twoofusllc-developement-team/productdeliveryplatform-server/tree/abbas-internship',
  },
  {
    title: 'Spotify Redesign',
    desc: lang === 'fr'
      ? "Refonte complète de l'interface Spotify avec nouvelles fonctionnalités."
      : "Full redesign of Spotify's interface with new features and improved UX.",
    tech: ['Laravel', 'PHP'],
    link: 'https://github.com/abbas-fakih39/spotify-redesign',
  },
  {
    title: 'Felikso',
    desc: lang === 'fr'
      ? "Site WordPress pour l'association lilloise Felikso."
      : 'WordPress website for the Lille association Felikso.',
    tech: ['WordPress'],
    link: 'https://www.felikso.org/',
  },
  {
    title: 'Tower Defense',
    desc: lang === 'fr'
      ? 'Jeu de stratégie Tower Defense — gestion de vagues et améliorations.'
      : 'Tower Defense strategy game with waves and upgrades system.',
    tech: ['Unity', 'C#'],
    link: 'https://github.com/ArthurFtn/Tower-defense',
  },
];
---

<section id="projects" class="pt-24 sm:pt-32">
  <div class="max-w-content w-full mx-auto px-6 lg:px-12">
    <!-- Section title over drawn rule -->
    <h2 class="section-title type-display uppercase text-fluid-title text-ink pb-4">
      {t('projects.title')}
    </h2>
    <div class="section-rule w-full" aria-hidden="true"></div>
  </div>

  <!-- Project rows with cyan sweep hover -->
  <div class="mt-6">
    {projects.map((project) => (
      <a
        href={project.link}
        target="_blank"
        rel="noopener noreferrer"
        class="project-row group relative block border-b border-line overflow-hidden"
      >
        <span class="project-sweep absolute inset-0 bg-signal -translate-x-full group-hover:translate-x-0 group-focus-visible:translate-x-0 transition-transform duration-300 ease-out" aria-hidden="true"></span>

        <div class="relative max-w-content mx-auto px-6 lg:px-12 py-8 sm:py-10 flex items-center justify-between gap-6">
          <div class="min-w-0">
            <h3 class="type-display uppercase text-fluid-title text-ink group-hover:text-signal-ink group-focus-visible:text-signal-ink transition-colors duration-200">
              {project.title}
            </h3>
            <p class="mt-2 text-[15px] text-muted group-hover:text-signal-ink group-focus-visible:text-signal-ink transition-colors duration-200 max-w-2xl">
              {project.desc}
              <span class="font-semibold"> — {project.tech.join(' · ')}</span>
            </p>
          </div>

          <span class="text-2xl text-muted group-hover:text-signal-ink group-hover:translate-x-2 group-focus-visible:text-signal-ink transition-all duration-300 flex-shrink-0" aria-hidden="true">→</span>
        </div>
      </a>
    ))}
  </div>

  <!-- GitHub CTA -->
  <div class="max-w-content mx-auto px-6 lg:px-12 py-10">
    <a
      href="https://github.com/abbas-fakih39"
      target="_blank"
      rel="noopener noreferrer"
      class="github-cta inline-flex items-center gap-2 py-2 text-sm font-semibold text-ink underline underline-offset-8 decoration-line hover:decoration-signal hover:text-signal transition-colors duration-200"
    >
      {t('projects.github')}
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    gsap.from('#projects .section-rule', {
      scaleX: 0, duration: 1, ease: 'power4.out',
      scrollTrigger: { trigger: '#projects', start: 'top 78%' },
    });
    gsap.from('#projects .section-title', {
      y: 24, opacity: 0, duration: 0.7, ease: 'power4.out',
      scrollTrigger: { trigger: '#projects', start: 'top 78%' },
    });
    gsap.utils.toArray<HTMLElement>('#projects .project-row').forEach((row) => {
      gsap.from(row, {
        y: 44, opacity: 0, duration: 0.7, ease: 'power4.out',
        scrollTrigger: { trigger: row, start: 'top 90%' },
      });
    });
  }
</script>

---
import { getLangFromUrl } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const year = new Date().getFullYear();
---

<footer class="py-12" style="border-top: 1px solid var(--border);">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">

      <a
        href={`/${lang}`}
        class="font-bold text-lg hover:text-accent transition-colors duration-300"
        style="font-family: 'Syne', sans-serif;"
      >
        AZF<span style="color: var(--accent)">.</span>
      </a>

      <p style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; letter-spacing: 0.15em; color: var(--muted); text-transform: uppercase;">
        © {year} Abbas Zein Fakih
      </p>

      <div class="flex items-center gap-6">
        <a
          href="https://github.com/abbas-fakih39"
          target="_blank"
          style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color 0.3s;"
          onmouseover="this.style.color='#fff'"
          onmouseout="this.style.color='var(--muted)'"
        >
          GitHub
        </a>
        <a
          href="https://www.linkedin.com/in/abbas-zein-fakih-b8649022b/"
          target="_blank"
          style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color 0.3s;"
          onmouseover="this.style.color='#fff'"
          onmouseout="this.style.color='var(--muted)'"
        >
          LinkedIn
        </a>
        <a
          href="/cv/mon-cv.pdf"
          download
          style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color 0.3s;"
          onmouseover="this.style.color='#fff'"
          onmouseout="this.style.color='var(--muted)'"
        >
          CV ↓
        </a>
      </div>

    </div>
  </div>

  <!-- Back to top -->
  <button
    id="back-to-top"
    class="fixed bottom-8 right-8 w-10 h-10 flex items-center justify-center opacity-0 invisible transition-all duration-300"
    style="border: 1px solid var(--border); background: var(--surface); color: var(--muted);"
    aria-label="Back to top"
    onmouseover="this.style.borderColor='var(--accent)'; this.style.color='#fff';"
    onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--muted)';"
  >
    <i class="fa fa-chevron-up text-xs"></i>
  </button>
</footer>

<script is:inline>
  const btt = document.getElementById('back-to-top');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 400) {
      btt.style.opacity = '1';
      btt.style.visibility = 'visible';
    } else {
      btt.style.opacity = '0';
      btt.style.visibility = 'hidden';
    }
  });
  btt.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
</script>

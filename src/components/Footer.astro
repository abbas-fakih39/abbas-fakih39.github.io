---
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const year = new Date().getFullYear();
---

<footer class="border-t border-border">
  <div class="max-w-content mx-auto px-6 lg:px-12 h-14 flex items-center justify-between">
    <p class="font-mono text-[11px] text-fg-dim">
      &copy; {year} Abbas Zein Fakih
    </p>
    <p class="font-mono text-[11px] text-fg-dim hidden sm:block">
      {lang === 'fr' ? 'Fait avec soin' : 'Made with care'}
    </p>
    <button
      id="back-to-top"
      class="font-mono text-[11px] text-fg-dim hover:text-accent transition-colors duration-200 sm:hidden"
      aria-label="Back to top"
    >
      ↑ Top
    </button>
  </div>
</footer>

<button
  id="back-to-top-desk"
  class="fixed bottom-6 right-6 z-50 opacity-0 invisible w-9 h-9 rounded-full bg-fg text-bg text-sm flex items-center justify-center hover:bg-accent hover:text-white transition-all duration-200"
  aria-label="Back to top"
>
  ↑
</button>

<script is:inline>
  (function() {
    const bttDesk = document.getElementById('back-to-top-desk');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 500) {
        bttDesk.style.opacity = '1';
        bttDesk.style.visibility = 'visible';
      } else {
        bttDesk.style.opacity = '0';
        bttDesk.style.visibility = 'hidden';
      }
    });
    bttDesk.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

    const bttMobile = document.getElementById('back-to-top');
    if (bttMobile) {
      bttMobile.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    }
  })();
</script>

---
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const year = new Date().getFullYear();
---

<footer class="border-t border-fg-dim">
  <div class="max-w-content mx-auto px-6 lg:px-16 h-14 flex items-center justify-between">
    <p class="font-mono text-[9px] tracking-[0.18em] uppercase text-fg-dim">
      &copy; {year} Abbas Zein Fakih
    </p>
    <p class="font-mono text-[9px] tracking-[0.18em] uppercase text-fg-dim hidden sm:block">
      {lang === 'fr' ? 'Fin de transmission' : 'End of transmission'}
    </p>
    <button
      id="back-to-top"
      class="font-mono text-[9px] tracking-[0.18em] uppercase text-fg-muted hover:text-fg transition-colors duration-300 sm:hidden"
      aria-label="Back to top"
    >
      ↑
    </button>
  </div>
</footer>

<button
  id="back-to-top-desk"
  class="fixed bottom-6 right-6 z-50 opacity-0 invisible font-mono text-[9px] tracking-widest uppercase text-fg-dim hover:text-fg transition-all duration-300"
  aria-label="Back to top"
>
  ↑
</button>

<script is:inline>
  (function() {
    const bttDesk = document.getElementById('back-to-top-desk');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 500) {
        bttDesk.style.opacity = '1';
        bttDesk.style.visibility = 'visible';
      } else {
        bttDesk.style.opacity = '0';
        bttDesk.style.visibility = 'hidden';
      }
    });
    bttDesk.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

    const bttMobile = document.getElementById('back-to-top');
    if (bttMobile) {
      bttMobile.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    }
  })();
</script>

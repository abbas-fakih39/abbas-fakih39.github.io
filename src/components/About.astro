---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const blocks = [
  { title: t('about.block1.title'), body: t('about.block1.body') },
  { title: t('about.block2.title'), body: t('about.block2.body') },
];

const stats = [
  { value: '3',   label: t('about.stats.years') },
  { value: '5+',  label: t('about.stats.projects') },
  { value: '10+', label: t('about.stats.tech') },
];

const statement = lang === 'fr'
  ? 'Développeur full-stack basé à Lille, je conçois des interfaces et des API pour de vrais produits.'
  : 'Full-stack developer based in Lille, building interfaces and APIs for real products.';
---

<section id="about" class="border-t border-border">
  <div class="max-w-content w-full mx-auto px-6 lg:px-12">

    <!-- Section header -->
    <div class="flex items-center gap-4 py-5 border-b border-border section-header-anim">
      <span class="font-mono text-[11px] text-fg-dim tracking-widest">01</span>
      <span class="w-px h-4 bg-border"></span>
      <span class="font-mono text-[11px] uppercase tracking-widest text-fg-dim">{t('about.label')}</span>
    </div>

    <!-- Statement -->
    <p class="mt-12 sm:mt-16 font-display font-semibold leading-tight max-w-3xl fade-up"
       style="font-size: clamp(1.5rem, 3.5vw, 2.4rem);">
      {statement}
    </p>

    <!-- Stats + Photo row -->
    <div class="mt-12 sm:mt-16 grid grid-cols-3 lg:grid-cols-4 border-t border-border fade-up">
      {stats.map((stat, i) => (
        <div class={`py-8 sm:py-10 border-r border-border pr-6 sm:pr-10 ${i > 0 ? 'pl-6 sm:pl-10' : ''}`}>
          <span class="block font-display font-bold text-fg leading-none"
                style="font-size: clamp(2rem, 5vw, 3.5rem);">
            {stat.value}
          </span>
          <span class="block mt-2 font-mono text-[10px] tracking-widest uppercase text-fg-dim">
            {stat.label}
          </span>
        </div>
      ))}
      <!-- Photo (desktop only, 4th column) -->
      <div class="hidden lg:flex items-center justify-end pl-10 py-8">
        <div class="w-28 h-36 rounded-lg overflow-hidden bg-surface border border-border">
          <img
            src="/images/votre-photo.jpg"
            alt="Abbas Fakih"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>

    <!-- Two text blocks -->
    <div class="grid grid-cols-1 lg:grid-cols-2 border-t border-border">
      {blocks.map((block, i) => (
        <div class={`py-10 sm:py-14 fade-up ${i === 0 ? 'lg:border-r lg:border-border lg:pr-12' : 'lg:pl-12'} ${i > 0 ? 'border-t lg:border-t-0 border-border' : ''}`}>
          <p class="font-mono text-[10px] tracking-widest uppercase text-fg-dim mb-5">
            {block.title}
          </p>
          <p class="text-fg-mid leading-relaxed text-[15px] sm:text-base">
            {block.body}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.to('#about .section-header-anim', {
    opacity: 1, y: 0, duration: 0.6,
    scrollTrigger: { trigger: '#about', start: 'top 78%' },
  });

  gsap.utils.toArray<HTMLElement>('#about .fade-up').forEach((el, i) => {
    gsap.to(el, {
      opacity: 1, y: 0, duration: 0.7,
      delay: i * 0.08,
      scrollTrigger: { trigger: el, start: 'top 82%' },
    });
  });
</script>

---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const blocks = [
  { title: t('about.block1.title'), body: t('about.block1.body') },
  { title: t('about.block2.title'), body: t('about.block2.body') },
];

const stats = [
  { value: '3',   label: t('about.stats.years').toLowerCase() },
  { value: '5+',  label: t('about.stats.projects').toLowerCase() },
  { value: '10+', label: t('about.stats.tech').toLowerCase() },
];

const statement = lang === 'fr'
  ? 'Développeur full-stack basé à Lille, je conçois des interfaces et des API pour de vrais produits.'
  : 'Full-stack developer based in Lille, building interfaces and APIs for real products.';
---

<section id="about" class="pt-24 sm:pt-32">
  <div class="max-w-content w-full mx-auto px-6 lg:px-12">

    <!-- Section title over drawn rule -->
    <h2 class="section-title type-display uppercase text-fluid-title text-ink pb-4">
      {t('about.title')}
    </h2>
    <div class="section-rule w-full" aria-hidden="true"></div>

    <!-- Statement -->
    <p class="about-statement mt-14 sm:mt-20 font-semibold text-ink leading-snug max-w-3xl"
       style="font-size: clamp(1.5rem, 3.2vw, 2.4rem); font-stretch: 110%;">
      {statement}
    </p>

    <!-- Stats as a running line -->
    <p class="about-stats mt-10 text-fluid-xl font-semibold text-ink max-w-3xl">
      {stats.map((stat, i) => (
        <>
          <span class="text-signal">{stat.value}</span> {stat.label}{i < stats.length - 1 && <span class="text-muted mx-2" aria-hidden="true">·</span>}
        </>
      ))}
    </p>

    <!-- Two text blocks, asymmetric -->
    <div class="mt-16 sm:mt-24 grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20">
      {blocks.map((block) => (
        <div class="about-block max-w-prose">
          <h3 class="text-base font-bold text-ink mb-4">
            {block.title}
          </h3>
          <p class="text-muted leading-relaxed">
            {block.body}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    gsap.from('#about .section-rule', {
      scaleX: 0, duration: 1, ease: 'power4.out',
      scrollTrigger: { trigger: '#about', start: 'top 78%' },
    });
    gsap.from('#about .section-title', {
      y: 24, opacity: 0, duration: 0.7, ease: 'power4.out',
      scrollTrigger: { trigger: '#about', start: 'top 78%' },
    });
    gsap.from('#about .about-statement', {
      y: 30, opacity: 0, duration: 0.8, ease: 'power4.out',
      scrollTrigger: { trigger: '#about .about-statement', start: 'top 85%' },
    });
    gsap.from('#about .about-stats', {
      y: 24, opacity: 0, duration: 0.7, ease: 'power4.out',
      scrollTrigger: { trigger: '#about .about-stats', start: 'top 88%' },
    });
    gsap.from('#about .about-block', {
      y: 32, opacity: 0, duration: 0.7, stagger: 0.12, ease: 'power4.out',
      scrollTrigger: { trigger: '#about .about-block', start: 'top 85%' },
    });
  }
</script>

---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const blocks = [
  { title: t('about.block1.title'), body: t('about.block1.body') },
  { title: t('about.block2.title'), body: t('about.block2.body') },
];

const stats = [
  { value: '3',   label: t('about.stats.years') },
  { value: '5+',  label: t('about.stats.projects') },
  { value: '10+', label: t('about.stats.tech') },
];

const statement = lang === 'fr'
  ? 'Développeur full-stack basé à Lille, je conçois des interfaces et des API pour de vrais produits.'
  : 'Full-stack developer based in Lille, building interfaces and APIs for real products.';
---

<section id="about" class="border-t border-fg-dim">
  <div class="max-w-content w-full mx-auto px-6 lg:px-16">

    <!-- Section header -->
    <div class="flex items-baseline gap-5 py-5 border-b border-fg-dim section-header-anim">
      <span class="font-display font-black text-fg-dim text-3xl sm:text-4xl leading-none">01</span>
      <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-fg-muted">{t('about.label')}</span>
    </div>

    <!-- Statement -->
    <p class="mt-12 sm:mt-16 font-display font-black leading-[1.05] tracking-tight max-w-4xl fade-up"
       style="font-size: clamp(1.6rem, 4vw, 3.5rem);">
      {statement}
    </p>

    <!-- Stats -->
    <div class="mt-12 sm:mt-16 grid grid-cols-3 border-t border-fg-dim fade-up">
      {stats.map((stat, i) => (
        <div class={`py-8 sm:py-10 ${i < 2 ? 'border-r border-fg-dim' : ''} ${i > 0 ? 'pl-6 sm:pl-10' : ''}`}>
          <span class="block font-display font-black text-fg leading-none"
                style="font-size: clamp(2.5rem, 6vw, 5rem);">
            {stat.value}
          </span>
          <span class="block mt-2 font-mono text-[9px] tracking-[0.18em] uppercase text-fg-muted">
            {stat.label}
          </span>
        </div>
      ))}
    </div>

    <!-- Two text blocks -->
    <div class="grid grid-cols-1 lg:grid-cols-2 border-t border-fg-dim">
      {blocks.map((block, i) => (
        <div class={`py-10 sm:py-14 fade-up ${i === 0 ? 'lg:border-r lg:border-fg-dim lg:pr-12' : 'lg:pl-12'}`}>
          <p class="font-mono text-[9px] tracking-[0.2em] uppercase text-fg-dim mb-5">
            {block.title}
          </p>
          <p class="text-fg-muted leading-relaxed" style="font-size: clamp(0.875rem, 1.3vw, 1rem); line-height: 1.8;">
            {block.body}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.to('#about .section-header-anim', {
    opacity: 1, y: 0, duration: 0.7,
    scrollTrigger: { trigger: '#about', start: 'top 75%' },
  });

  gsap.utils.toArray('#about .fade-up').forEach((el, i) => {
    gsap.to(el, {
      opacity: 1, y: 0, duration: 0.8,
      delay: i * 0.1,
      scrollTrigger: { trigger: el, start: 'top 80%' },
    });
  });
</script>
